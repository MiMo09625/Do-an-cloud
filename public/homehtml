<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"> <!-- Đã sửa từ mela thành meta -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evernote Clone - Pro Version</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="user-profile">
                    <span id="userNameDisplay">Đang tải...</span>
                    <i class="fas fa-cog settings-icon"></i>
                </div>
                <button class="btn-green">+ Ghi chú mới</button>
            </div>
            <!-- Các phần khác giữ nguyên -->
        </aside>
        <main class="main-content">
            <div id="editor">Chọn hoặc tạo ghi chú mới</div>
        </main>
    </div>
    <script src="script.js"></script>
</body>
</html>
